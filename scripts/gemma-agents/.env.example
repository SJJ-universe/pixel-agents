# Copy to ".env" (gitignored) and fill in. The runner reads this automatically.
OPENROUTER_API_KEY=sk-or-your-key-here

# Lightweight Gemma 4 by default (26B total, only ~4B active params → fast + cheap).
# Pick any real Gemma model on OpenRouter:
#   google/gemma-4-26b-a4b-it        (default — lightweight Gemma 4, ~$0.06/Mtok in)
#   google/gemma-4-26b-a4b-it:free   (same model, free tier — may rate-limit with 7 agents)
#   google/gemma-4-31b-it            (heavier Gemma 4, dense 31B)
#   google/gemma-3-4b-it             (tiny Gemma 3, cheapest)
GEMMA_MODEL=google/gemma-4-26b-a4b-it

# Optional:
# AGENTS=7
# PORT=7777
